<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Carlos Fandango</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Personal homepage of Carlos Fandango — projects, writing, and work from Devon.{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="nav-home">CF</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
      </div>
    </nav>
  </header>

  <main class="main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>Carlos Fandango &mdash; Devon, UK</p>
  </footer>
</body>
</html>
